    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const aiText = $input.item.json.output;\n\nlet classification;\ntry {\n  classification = JSON.parse(aiText);\n} catch (e) {\n  throw new Error(`Classify email non ha restituito JSON valido. Output ricevuto: ${(aiText ?? '').slice(0, 300)}`);\n}\n\nconst original = $('Pre-filter spam').item.json;\n\nreturn {\n  json: {\n    category: classification.category,\n    confidence: classification.confidence,\n    reasoning: classification.reasoning,\n    subject: original.subject,\n    from: original.from,\n    text: original.text,\n    messageId: original.messageId,\n    classifiedAt: new Date().toISOString(),\n    draft: null,\n    draftConfidence: null,\n    draftRationale: null,\n  },\n};\n"
      },
