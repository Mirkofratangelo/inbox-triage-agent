      "id": "399fa0bf-6899-430a-8f5c-b3e41265488a",
      "name": "Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [
        -464,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const NOISE_SENDER_RE = /(no[-_.]?reply|noreply|donot[-_.]?reply|do[-_.]?not[-_.]?reply|notifications?@|news(letter)?@|mailer@|bounce@|newsletter)/i;\nconst NOISE_SUBJECT_RE = /(unsubscribe|view in browser|view this email in your browser|news(letter)?\\b|weekly digest|daily digest)/i;\n\nconst all = $input.all();\nconst out = [];\n\nfor (const item of all) {\n  const j = item.json ?? {};\n  const subject = j.subject ?? j.headers?.subject ?? '';\n  const fromAddr = j.from?.value?.[0]?.address ?? j.headers?.from ?? '';\n  const text = j.text ?? '';\n  const messageId = j.id ?? j.messageId ?? j.headers?.['message-id'] ?? '';\n\n  if (NOISE_SENDER_RE.test(fromAddr) || NOISE_SUBJECT_RE.test(subject)) {\n    continue;\n  }\n\n  out.push({\n    json: {\n      subject,\n      from: fromAddr,\n      text: text.slice(0, 4000),\n      messageId,\n    },\n  });\n}\n\nconsole.log(`Pre-filter: ${all.length} ricevute · ${out.length} passate · ${all.length - out.length} scartate`);\nreturn out;\n"
      },
      "id": "895be0e4-a041-448b-913e-40b36d126b73",
      "name": "Pre-filter spam",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        304
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={\n  \"subject\": {{ JSON.stringify($json.subject) }},\n  \"from\": {{ JSON.stringify($json.from) }},\n  \"text\": {{ JSON.stringify($json.text) }}\n}",
        "options": {
          "systemMessage": "You are a triage assistant for a small e-commerce/business owner's email inbox.\nYou receive ONE email as JSON: { \"subject\", \"from\", \"text\" }.\nReturn ONLY a JSON object, no other text:\n{ \"category\": \"auto_bozza\" | \"richiede_te\" | \"rumore\", \"confidence\": 0.0-1.0, \"reasoning\": \"<max 8 words>\" }\nDecision, IN ORDER (first matching rule wins):\n1. Spam, promotions, newsletters, automated notifications -> \"rumore\"\n2. Anything involving a decision, money, a return/refund, a complaint, negative tone, a non-standard request, or ambiguity -> \"richiede_te\"\n3. Standard repetitive question (order status, shipping, sizes/variants, return policy) -> \"auto_bozza\"\nWhen in doubt between auto_bozza and richiede_te -> ALWAYS choose \"richiede_te\"."
        }
      },
      "id": "6188889d-25ab-4468-aad9-eb33e8cafc69",
      "name": "Classify email",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        0,
        304
      ]
