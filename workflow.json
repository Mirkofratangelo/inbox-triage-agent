    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const aiText = $input.item.json.output;\n\nlet reply;\ntry {\n  reply = JSON.parse(aiText);\n} catch (e) {\n  throw new Error(`Generate bozza non ha restituito JSON valido. Output ricevuto: ${(aiText ?? '').slice(0, 300)}`);\n}\n\nconst classified = $('Route by category').item.json;\nconst hasDraft = !!(reply.reply_draft && reply.reply_draft.length > 0);\n\nreturn {\n  json: {\n    category: classified.category,\n    confidence: classified.confidence,\n    reasoning: classified.reasoning,\n    subject: classified.subject,\n    from: classified.from,\n    text: classified.text,\n    messageId: classified.messageId,\n    classifiedAt: classified.classifiedAt,\n    draft: hasDraft ? reply.reply_draft : '',\n    draftConfidence: hasDraft ? (reply.confidence ?? null) : null,\n    draftRationale: reply.rationale ?? null,\n  },\n};\n"
      },
