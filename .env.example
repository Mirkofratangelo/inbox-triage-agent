# =============================================================================
# Inbox Triage Agent — values to gather before importing the workflow
# =============================================================================
#
# This file is NOT loaded automatically by n8n. The workflow uses n8n's
# built-in Credentials system (set up in the n8n UI). This file is a
# checklist of what you need to have on hand. Copy it to ".env" locally if
# you want to keep your keys somewhere, but never commit the real ".env".
#
# See docs/setup.md for step-by-step instructions on where each value goes.

# -----------------------------------------------------------------------------
# Anthropic Claude API
# -----------------------------------------------------------------------------
# Used by the two LLM nodes (classify + draft). One key, both nodes reuse it.
# Get yours at https://console.anthropic.com (Settings -> API Keys).
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# -----------------------------------------------------------------------------
# Gmail OAuth
# -----------------------------------------------------------------------------
# Used by the "Gmail" node to read incoming messages (read-only scope).
# You will create an OAuth client in Google Cloud Console and paste its
# Client ID / Client Secret into the Gmail credential inside n8n.
# Full walkthrough: docs/setup.md
GMAIL_OAUTH_CLIENT_ID=YOUR_GMAIL_OAUTH_CLIENT_ID
GMAIL_OAUTH_CLIENT_SECRET=YOUR_GMAIL_OAUTH_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Google Sheets OAuth
# -----------------------------------------------------------------------------
# Used by the two "Sheets" nodes to append rows to your triage spreadsheet.
# In Google Cloud you can reuse the same OAuth client as Gmail — just enable
# the Google Sheets API on the same project.
GOOGLE_SHEETS_OAUTH_CLIENT_ID=YOUR_GOOGLE_SHEETS_OAUTH_CLIENT_ID
GOOGLE_SHEETS_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_SHEETS_OAUTH_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Google Sheet target
# -----------------------------------------------------------------------------
# The ID of the spreadsheet you create for triage results. It must have two
# tabs named exactly:
#   - "Bozze da rivedere" (columns: data | from | subject | messaggio | bozza)
#   - "Richiede te"       (columns: data | from | subject | messaggio | motivo)
# The ID is the long string between /d/ and /edit in the sheet URL.
GOOGLE_SHEET_ID=YOUR_SPREADSHEET_ID
